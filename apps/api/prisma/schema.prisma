generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum UserRole {
  admin
  agent
}

enum ContactStatus {
  new
  active
  inactive
  archived
}

enum TaskStatus {
  pending
  in_progress
  done
  cancelled
}

enum MessageDirection {
  inbound
  outbound
}

enum MessageChannel {
  whatsapp
  email
  sms
}

enum MessageStatus {
  sent
  delivered
  read
  failed
}

enum FlowExecutionStatus {
  running
  completed
  failed
  cancelled
}

// ─── Models ───────────────────────────────────────────────────────────────────

model User {
  id        String    @id @default(uuid())
  email     String    @unique
  password  String
  name      String
  role      UserRole  @default(agent)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  contacts  Contact[]
  tasks     Task[]
}

model Contact {
  id           String        @id @default(uuid())
  name         String
  phone        String        @unique
  email        String?
  status       ContactStatus @default(new)
  assignedToId String?
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  assignedTo User?           @relation(fields: [assignedToId], references: [id])
  flows      FlowExecution[]
  messages   Message[]
  tasks      Task[]
  tags       Tag[]           @relation("ContactToTag")
}

model Task {
  id           String     @id @default(uuid())
  title        String
  description  String?
  status       TaskStatus @default(pending)
  dueDate      DateTime?
  contactId    String
  assignedToId String?
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  assignedTo User?    @relation(fields: [assignedToId], references: [id])
  contact    Contact  @relation(fields: [contactId], references: [id])
}

model Message {
  id        String           @id @default(uuid())
  subject   String?
  content   String
  direction MessageDirection
  channel   MessageChannel   @default(whatsapp)
  status    MessageStatus    @default(sent)
  contactId String
  // wamid: WhatsApp Message ID returned by Meta after sending.
  // Required to match incoming status webhooks (delivered, read, failed).
  wamid     String?          @unique
  createdAt DateTime         @default(now())

  contact Contact @relation(fields: [contactId], references: [id])
}

model Template {
  id        String   @id @default(uuid())
  name      String
  content   String
  category  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Flow {
  id         String          @id @default(uuid())
  name       String
  trigger    String
  steps      Json
  active     Boolean         @default(true)
  createdAt  DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  executions FlowExecution[]
}

model FlowExecution {
  id         String              @id @default(uuid())
  flowId     String
  contactId  String
  status     FlowExecutionStatus @default(running)
  startedAt  DateTime            @default(now())
  finishedAt DateTime?

  contact Contact @relation(fields: [contactId], references: [id])
  flow    Flow    @relation(fields: [flowId], references: [id])
}

model Tag {
  id        String    @id @default(uuid())
  name      String    @unique
  createdAt DateTime  @default(now())

  contacts Contact[] @relation("ContactToTag")
}
